{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "types": ["node"],

    "rootDir": "./",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "exactOptionalPropertyTypes": false,
    
    "jsx": "react-jsx"
  },
  "include": ["**/*.ts", ".env"],
  "exclude": ["node_modules", "dist"]
}